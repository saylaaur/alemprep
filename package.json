    "gen:verify": "tsx --tsconfig tsconfig.scripts.json scripts/verify-questions.ts",
    "gen:insert": "tsx --tsconfig tsconfig.scripts.json scripts/insert-to-db.ts",
    "gen:all": "tsx --tsconfig tsconfig.scripts.json scripts/gen-all.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@radix-ui/react-slot": "^1.1.0",
